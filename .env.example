# ============================================================
# ScopeMaster — Variáveis de Ambiente
# ============================================================
# Copie este arquivo para `.env` na raiz do projeto e preencha
# com as credenciais reais do seu projeto Supabase.
#
# IMPORTANTE: nunca commite o arquivo `.env` real — ele está
# listado no .gitignore. Use a interface do Vercel (Settings
# > Environment Variables) para configurar essas variáveis
# em produção.
# ============================================================

# URL do projeto Supabase
# Encontre em: Supabase Dashboard > Project Settings > API > Project URL
VITE_SUPABASE_URL=https://SEU_PROJETO.supabase.co

# Chave pública (anon) do Supabase
# Encontre em: Supabase Dashboard > Project Settings > API > Project API keys > anon public
# Esta chave é segura para o frontend desde que as políticas de RLS estejam configuradas.
VITE_SUPABASE_ANON_KEY=eyJhbGciOi...sua_chave_anon_aqui...
